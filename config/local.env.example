AI_QUANT_ENVIRONMENT=local
AI_QUANT_DEMO_MODE=false
AI_QUANT_MARKET_DATA_PROVIDER=yahoo
AI_QUANT_MARKET_DATA_CACHE_TTL_SECONDS=60
AI_QUANT_DATABASE_URL=postgresql+psycopg://quant:quant@postgres:5432/quant
AI_QUANT_REDIS_URL=redis://redis:6379/0
AI_QUANT_CORS_ORIGINS=["http://localhost:3000"]

# Options-chain data defaults to Yahoo (no signup required), but its options
# endpoint blocks server/datacenter IPs more aggressively than its chart
# endpoint, so it can be unreliable in production even when regular price
# history works fine. Free alternative: sign up for a Tradier brokerage
# sandbox account via tradier.com (navigate their site for current developer/
# API signup — specific deep links there change over time), then set:
# AI_QUANT_OPTIONS_DATA_PROVIDER=tradier
# AI_QUANT_TRADIER_API_TOKEN=<your sandbox token>
# AI_QUANT_TRADIER_BASE_URL=https://sandbox.tradier.com/v1
